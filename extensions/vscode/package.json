{
  "name": "qa-brain-vscode-client",
  "displayName": "QA Brain",
  "description": "VS Code client for QA Brain rule-only Playwright test reviews.",
  "version": "0.1.0",
  "publisher": "qa-brain",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Testing",
    "Linters"
  ],
  "activationEvents": [
    "onCommand:qaBrain.reviewCurrentFile",
    "onCommand:qaBrain.reviewSelection",
    "onCommand:qaBrain.reviewChangedFiles",
    "onCommand:qaBrain.openLatestReport",
    "onCommand:qaBrain.clearDiagnostics",
    "onLanguage:typescript",
    "onLanguage:javascript",
    "onLanguage:python"
  ],
  "main": "./out/src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "qaBrain.reviewCurrentFile",
        "title": "QA Brain: Review Current Test File"
      },
      {
        "command": "qaBrain.reviewSelection",
        "title": "QA Brain: Review Selection"
      },
      {
        "command": "qaBrain.reviewChangedFiles",
        "title": "QA Brain: Review Changed Files"
      },
      {
        "command": "qaBrain.openLatestReport",
        "title": "QA Brain: Open Latest Report"
      },
      {
        "command": "qaBrain.clearDiagnostics",
        "title": "QA Brain: Clear Diagnostics"
      },
      {
        "command": "qaBrain.showFindingDetails",
        "title": "QA Brain: Show Finding Details"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "qa-brain-sidebar",
          "title": "QA Brain",
          "icon": "$(beaker)"
        }
      ]
    },
    "views": {
      "qa-brain-sidebar": [
        {
          "type": "webview",
          "id": "qaBrain.sidebarView",
          "name": "QA Brain Dashboard"
        }
      ]
    },
    "configuration": {
      "title": "QA Brain",
      "properties": {
        "qaBrain.reviewMode": {
          "type": "string",
          "default": "rule-only",
          "enum": [
            "rule-only"
          ],
          "description": "Review mode. Supports rule-only mode."
        },
        "qaBrain.frameworkOverride": {
          "type": "string",
          "default": "Auto",
          "enum": [
            "Auto",
            "Playwright",
            "Selenium",
            "Disabled"
          ],
          "description": "Override framework detection. If Auto, QA Brain will automatically detect workspace framework dependencies. If Disabled, review on save is paused."
        },
        "qaBrain.reviewOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Run QA Brain when a supported test file is saved."
        },
        "qaBrain.openReportAfterReview": {
          "type": "boolean",
          "default": false,
          "description": "Open the generated Markdown report after each review."
        },
        "qaBrain.includePatterns": {
          "type": "array",
          "default": [
            "**/*.spec.ts",
            "**/*.test.ts",
            "**/*.spec.js",
            "**/*.test.js",
            "**/*.py",
            "**/test_*.py",
            "**/*_test.py"
          ],
          "items": {
            "type": "string"
          },
          "description": "File patterns eligible for QA Brain review."
        },
        "qaBrain.excludePatterns": {
          "type": "array",
          "default": [
            "**/node_modules/**",
            "**/dist/**",
            "**/build/**"
          ],
          "items": {
            "type": "string"
          },
          "description": "File patterns excluded from QA Brain review."
        },
        "qaBrain.showDiagnostics": {
          "type": "boolean",
          "default": true,
          "description": "Show QA Brain findings in the Problems panel."
        },
        "qaBrain.showCodeLens": {
          "type": "boolean",
          "default": true,
          "description": "Show QA Brain CodeLens summary on supported test files."
        },
        "qaBrain.showStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show QA Brain status bar item."
        },
        "qaBrain.statusBarAttentionMode": {
          "type": "string",
          "default": "icon",
          "enum": ["off", "icon", "background"],
          "description": "How the status bar draws attention on errors. 'icon' changes emoji to warning, 'background' colors the entire status bar, 'off' disables indicators."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ."
  },
  "devDependencies": {}
}
