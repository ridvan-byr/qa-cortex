  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/ridvan-byr/qa-cortex/issues"
  },
  "homepage": "https://github.com/ridvan-byr/qa-cortex#readme",
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/github": "^9.1.1",
    "@google/genai": "^2.10.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.0",
    "@vitest/coverage-v8": "^1.6.0",
    "ts-node": "^10.9.2",
