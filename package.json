{
  "name": "qa-cortex",
  "version": "0.1.0",
  "description": "QA Cortex: AI-powered QA knowledge engine for test design, review and test generation.",
  "main": "./dist/src/cli.js",
  "bin": {
    "qa-cortex": "./dist/src/cli.js",
    "qa-cortex-mcp": "./dist/src/mcp.js"
  },
  "files": [
    "dist",
    "knowledge"
  ],
