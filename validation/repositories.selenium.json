{
  "framework": "selenium",
  "reportTitle": "QA Cortex Selenium Calibration & Validation Report",
  "maxFilesPerRepository": 50,
  "runGeminiComparison": false,
  "outputDir": "validation/reports",
  "markdownReportName": "selenium-calibration-report.md",
  "jsonReportName": "selenium-calibration-report.json",
  "metricsOutputPath": "validation/metrics/selenium-calibration-metrics.json",
  "ignorePatterns": [
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**",
    "**/.git/**",
    "**/src/test.ts"
  ],
  "repositories": [
    {
      "id": "selenium-01",
      "name": "selenium-javascript-test",
      "url": "https://github.com/sadabnepal/selenium-javascript-test.git",
      "localPath": "validation/repos/selenium-javascript-test",
      "size": "small",
      "tags": ["selenium", "javascript", "mocha", "chai"]
    },
    {
      "id": "selenium-02",
      "name": "selenium-mocha",
      "url": "https://github.com/kiseta/selenium-mocha.git",
      "localPath": "validation/repos/selenium-mocha",
      "size": "small",
      "tags": ["selenium", "mocha", "pom"]
    },
    {
      "id": "selenium-03",
      "name": "mocha-selenium-sample",
      "url": "https://github.com/LambdaTest/mocha-selenium-sample.git",
      "localPath": "validation/repos/mocha-selenium-sample",
      "size": "small",
      "tags": ["selenium", "lambdatest", "mocha"]
    },
    {
      "id": "selenium-04",
      "name": "demo-js",
      "url": "https://github.com/saucelabs/demo-js.git",
      "localPath": "validation/repos/demo-js/selenium",
      "size": "small",
      "tags": ["selenium", "saucelabs", "javascript"]
    },
    {
      "id": "selenium-python-01",
      "name": "python-selenium-framework-example",
      "url": "https://github.com/adrianmaciuc/python-selenium-framework-example.git",
      "localPath": "validation/repos/python-selenium-framework-example",
      "size": "small",
      "tags": ["selenium", "python", "pytest", "pom"]
    },
    {
      "id": "selenium-python-02",
      "name": "example-pytest-selenium",
      "url": "https://github.com/testery/example-pytest-selenium.git",
      "localPath": "validation/repos/example-pytest-selenium",
      "size": "small",
      "tags": ["selenium", "python", "pytest", "minimal"]
    },
    {
      "id": "selenium-python-03",
      "name": "selenium-boilerplate",
      "url": "https://github.com/emZubair/selenium-boilerplate.git",
      "localPath": "validation/repos/selenium-boilerplate",
      "size": "small",
      "tags": ["selenium", "python", "boilerplate", "pom"]
    }
  ]
}
